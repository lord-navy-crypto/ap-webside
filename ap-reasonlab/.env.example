# AI keys — Hint Coach / AI Toolbox
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
KIMI_API_KEY=
# MOONSHOT_API_KEY=   # alias accepted for KIMI_API_KEY

# Cloud spend tier for website keys (not Local AI):
#   public (default) = Instant models, lowest token caps
#   author | mid | standard = mid versatile models, modestly higher caps (not Instant)
# SITE_AI_TIER=public
# AUTHOR_AI_TIER=   # alias for SITE_AI_TIER

# Optional mid-tier model overrides when SITE_AI_TIER=author (or for BYOK defaults)
# AUTHOR_GROQ_MODEL=llama-3.3-70b-versatile
# AUTHOR_GEMINI_MODEL=gemini-2.0-flash
# AUTHOR_KIMI_MODEL=moonshot-v1-32k
# AUTHOR_OPENROUTER_MODEL=meta-llama/llama-3.1-70b-instruct
# AUTHOR_DEEPSEEK_MODEL=deepseek-chat
# AUTHOR_GITHUB_MODELS_MODEL=openai/gpt-4o-mini

# GitHub Models AI (owner uses CONTENT_GITHUB_TOKEN for this)
# Optional model id override, e.g. openai/gpt-4o-mini
CONTENT_GITHUB_TOKEN=
# GITHUB_MODELS_MODEL=openai/gpt-4o-mini

# Kimi / Moonshot (default CN endpoint; override if needed)
# KIMI_API_BASE=https://api.moonshot.cn/v1
# KIMI_MODEL=moonshot-v1-8k

# Optional model overrides for other providers
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct
# DEEPSEEK_MODEL=deepseek-chat
# OPENROUTER_SITE_URL=https://your-production-domain.example
# OPENROUTER_APP_NAME=Knowledge Explorer

# Change codes (unlock the edit UI). NOT GitHub tokens.
CONTENT_CHANGE_CODE=C-43620D98
MASTER_CHANGE_CODE=M-B67DDB61

# Cookie signing (optional)
AUTH_SECRET=

# Repo Save / publish — REAL write PAT (Contents read+write on ap-webside)
# This is separate from CONTENT_GITHUB_TOKEN (AI).
GITHUB_TOKEN=
GITHUB_REPO=lord-navy-crypto/ap-webside
GITHUB_BRANCH=main
