# AI API keys (optional — mock hints work without any key)
GROQ_API_KEY=
GEMINI_API_KEY=

# Manager UI auth
# Full admin password (you). Change this on Vercel.
ADMIN_PASSWORD=results-admin
# Partner / collaborator password (can upload content, cannot promote users)
PARTNER_PASSWORD=results-partner
# Cookie signing secret (any long random string)
AUTH_SECRET=

# Optional: publish Admin UI saves to GitHub so Vercel redeploys for everyone
# Create a fine-grained or classic token with Contents: Read/Write on this repo
GITHUB_TOKEN=
GITHUB_REPO=lord-navy-crypto/ap-webside
GITHUB_BRANCH=main
