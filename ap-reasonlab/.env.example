# AI keys (Hint Coach / AI Toolbox) — NOT used for Save / GitHub publish
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=

# Optional model overrides
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct
# DEEPSEEK_MODEL=deepseek-chat
# OPENROUTER_SITE_URL=https://your-production-domain.example
# OPENROUTER_APP_NAME=Results Academic Platform

# Change codes (unlock the edit UI). NOT GitHub tokens.
CONTENT_CHANGE_CODE=C-43620D98
MASTER_CHANGE_CODE=M-B67DDB61

# Cookie signing (optional)
AUTH_SECRET=

# GitHub write / publish (Save button) — NOT an AI model key.
# Name means: "token that publishes CONTENT to GitHub".
# Put your real GitHub PAT here (ghp_ or github_pat_). Same PAT can also be GITHUB_TOKEN.
# Code tries CONTENT_GITHUB_TOKEN, then GITHUB_TOKEN, then GH_TOKEN.
CONTENT_GITHUB_TOKEN=
GITHUB_TOKEN=
GITHUB_REPO=lord-navy-crypto/ap-webside
GITHUB_BRANCH=main
